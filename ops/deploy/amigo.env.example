# Required LLM credentials
MODEL_API_KEY=your_api_key
MODEL_NAME=qwen3-coder
MODEL_BASE_URL=https://openrouter.ai/api/v1
LLM_TEMPERATURE=0

# Amigo packaged app runtime
AMIGO_PORT=10013
AMIGO_CACHE_PATH=/var/www/amigo/cache
AMIGO_SANDBOX_IMAGE=ai_sandbox
AMIGO_SANDBOX_RUNTIME=runsc
AMIGO_SANDBOX_MEMORY_MB=2048

# Required MySQL runtime
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=amigo
MYSQL_PASSWORD=change_me
MYSQL_DATABASE=amigo

# Required Better Auth runtime
BETTER_AUTH_SECRET=change_me_to_a_long_random_secret
# Production public base URL used by auth callbacks/cookies.
# Example: https://amigo.example.com
BETTER_AUTH_BASE_URL=https://amigo.example.com
# Comma-separated list of trusted browser origins.
# Example: https://amigo.example.com,https://www.amigo.example.com
BETTER_AUTH_TRUSTED_ORIGINS=https://amigo.example.com

# Optional hosted preview
# AMIGO_PREVIEW_BASE_DOMAIN=preview.example.com
# AMIGO_PREVIEW_PUBLIC_PROTOCOL=https

# Optional search
# SERPER_API_KEY=your_serper_api_key

# Optional GitHub token for private repo bootstrap / sandbox git push over HTTPS
# GITHUB_TOKEN=ghp_xxx

# Optional OSS upload secrets
# OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
# OSS_BUCKET=your-bucket
# OSS_ACCESS_KEY_ID=your-access-key-id
# OSS_ACCESS_KEY_SECRET=your-access-key-secret
# OSS_PUBLIC_BASE_URL=https://your-bucket.oss-cn-hangzhou.aliyuncs.com
# OSS_UPLOAD_PREFIX=uploads
# OSS_POLICY_EXPIRE_SECONDS=600
# OSS_SECURITY_TOKEN=

# Optional Penpot integration
# PENPOT_BASE_URL=https://penpot.example.com
# PENPOT_ACCESS_TOKEN=your_penpot_token
# PENPOT_TEAM_ID=team_id
# PENPOT_PROJECT_ID=project_id

# Optional Feishu integration
# FEISHU_APP_ID=cli_xxx
# FEISHU_APP_SECRET=xxx
# FEISHU_GROUP_MODE=at_only
# FEISHU_ACK_REACTION_TYPE=OK
