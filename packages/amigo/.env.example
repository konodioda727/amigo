# Required
MODEL_API_KEY=your_api_key

# Model
MODEL_NAME=qwen3-coder
MODEL_BASE_URL=https://openrouter.ai/api/v1
LLM_TEMPERATURE=0
# Optional: per-model context window / compression config
# Example:
# MODEL_CONTEXT_CONFIGS={"qwen3-coder":{"contextWindow":262144,"compressionThreshold":0.8,"targetRatio":0.5}}

# Server
SERVER_PORT=10013
STORAGE_PATH=./storage
LOG_LEVEL=INFO

# Optional search
# SERPER_API_KEY=your_serper_api_key

# Sandbox / preview
# Memory limit per sandbox container in MB
AMIGO_SANDBOX_MEMORY_MB=2048

# Optional: expose preview via wildcard subdomain
# AMIGO_PREVIEW_BASE_DOMAIN=preview.example.com
# AMIGO_PREVIEW_PUBLIC_PROTOCOL=https

# Optional OSS upload
# OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
# OSS_BUCKET=your-bucket
# OSS_ACCESS_KEY_ID=your-access-key-id
# OSS_ACCESS_KEY_SECRET=your-access-key-secret
# OSS_PUBLIC_BASE_URL=https://your-bucket.oss-cn-hangzhou.aliyuncs.com
# OSS_UPLOAD_PREFIX=uploads
# OSS_POLICY_EXPIRE_SECONDS=600
# OSS_SECURITY_TOKEN=

# Optional Penpot integration
# PENPOT_BASE_URL=https://penpot.example.com
# PENPOT_ACCESS_TOKEN=your_penpot_token
# PENPOT_TEAM_ID=your_team_id
# PENPOT_PROJECT_ID=your_project_id
