# Required
MODEL_API_KEY=your_api_key

# Model
MODEL_NAME=qwen3-coder
MODEL_BASE_URL=https://openrouter.ai/api/v1
LLM_TEMPERATURE=0

# Optional search
# SERPER_API_KEY=your_serper_api_key

# Optional GitHub token for private repo bootstrap / sandbox git push over HTTPS
# GITHUB_TOKEN=ghp_xxx

# Optional MySQL database for amigo server state
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USER=amigo
# MYSQL_PASSWORD=your_mysql_password
# MYSQL_DATABASE=amigo
# MYSQL_SSL=false
# BETTER_AUTH_SECRET=change-this-in-production
# BETTER_AUTH_BASE_URL=http://localhost:10013
# BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:10014,http://127.0.0.1:10014

# Optional OSS upload secrets
# OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
# OSS_BUCKET=your-bucket
# OSS_ACCESS_KEY_ID=your-access-key-id
# OSS_ACCESS_KEY_SECRET=your-access-key-secret
# OSS_PUBLIC_BASE_URL=https://your-bucket.oss-cn-hangzhou.aliyuncs.com
# OSS_UPLOAD_PREFIX=uploads
# OSS_POLICY_EXPIRE_SECONDS=600
# OSS_SECURITY_TOKEN=

# Optional Penpot integration secrets
# PENPOT_BASE_URL=https://penpot.example.com
# PENPOT_ACCESS_TOKEN=your_penpot_token
# PENPOT_TEAM_ID=team_id
# PENPOT_PROJECT_ID=project_id

# Optional Feishu bot integration
# FEISHU_APP_ID=cli_xxx
# FEISHU_APP_SECRET=xxx
# FEISHU_GROUP_MODE=at_only
# FEISHU_ACK_REACTION_TYPE=OK
