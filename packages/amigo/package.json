{
  "name": "@amigo-llm/amigo",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"bun run dev:server\" \"bun run dev:web\"",
    "start": "concurrently \"bun run start:server\" \"bun run start:web\"",
    "dev:server": "bun run src/server/index.ts --watch",
    "start:server": "bun run src/server/index.ts",
    "dev:web": "bun run src/web/dev.ts",
    "start:web": "bun run src/web/index.ts",
    "build": "bun run build:server && bun run build:web",
    "build:server": "bun run buildServer.ts",
    "build:web": "bun run build.ts"
  },
  "dependencies": {
    "@amigo-llm/backend": "workspace:*",
    "@amigo-llm/frontend": "workspace:*",
    "@amigo-llm/types": "workspace:*",
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "concurrently": "^9.2.1",
    "css-tree": "^3.2.1",
    "dotenv": "^17.2.3",
    "htmlparser2": "^10.1.0",
    "lucide-react": "^0.544.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.12.0",
    "streamdown": "^1.3.0",
    "yoga-layout": "^3.2.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "bun-plugin-tailwind": "^0.1.2",
    "daisyui": "^5.1.25",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.0.2"
  }
}
